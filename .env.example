# Copy to .env and fill in your values (never commit .env)
# This file is read by BOTH Spring Boot (spring.config.import) and docker-compose.

# --- Gemini (RAG chatbot) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_RETRIEVAL_LIMIT=5
GEMINI_ENABLED=true

# --- Database (values shared by docker-compose and the app) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dossia
POSTGRES_USER=dossia
POSTGRES_PASSWORD=dossia

# --- Auth / JWT ---
# JWT_SECRET MUST be at least 32 characters. Change it in production.
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRATION_MS=86400000
# Set to true when serving over HTTPS in production.
AUTH_COOKIE_SECURE=false

# --- Admin access ---
# Comma-separated emails. Any user registering with (or already having) one of
# these emails is granted the ADMIN role (required for /api/v1/admin/**).
ADMIN_EMAILS=admin@dosya.tn

# Used by scraper/import_to_api.py to authenticate against admin endpoints.
DOSSIA_ADMIN_EMAIL=admin@dosya.tn
DOSSIA_ADMIN_PASSWORD=change-me
